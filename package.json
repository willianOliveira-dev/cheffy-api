{
    "name": "cheffy-api",
    "type": "module",
    "scripts": {
        "dev": "pnpm exec dotenv -e .env -- tsx watch src/server.ts",
        "build": "rimraf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
        "start": "cross-env NODE_ENV=production node dist/server.js",
        "typecheck": "tsc --noEmit",
        "lint": "biome lint ./src",
        "lint:fix": "biome lint --write ./src",
        "format": "biome format --write ./src",
        "check": "biome check --write ./src",
        "prepare": "husky",
        "db:generate": "pnpm exec dotenv -e .env -- prisma generate",
        "db:migrate": "pnpm exec dotenv -e .env -- prisma migrate dev",
        "db:studio": "pnpm exec dotenv -e .env -- prisma studio"
    },
    "engines": {
        "node": ">=22.0.0",
        "pnpm": ">=9.0.0"
    },
    "dependencies": {
        "@hono/node-server": "^1.19.11",
        "@hono/zod-openapi": "1.4.0",
        "@hono/zod-validator": "0.7.6",
        "@prisma/adapter-pg": "7.5.0",
        "@prisma/client": "7.5.0",
        "better-auth": "1.5.6",
        "better-auth-localization": "3.0.0",
        "groq-sdk": "1.1.1",
        "hono": "^4.12.9",
        "pg": "8.20.0",
        "pino": "10.3.1",
        "pino-pretty": "13.1.3",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.8",
        "@commitlint/config-conventional": "20.5.0",
        "@types/node": "^20.11.17",
        "@types/pg": "8.11.11",
        "@types/pino": "7.0.5",
        "commitlint": "20.5.0",
        "cross-env": "10.1.0",
        "dotenv-cli": "11.0.0",
        "husky": "9.1.7",
        "lint-staged": "16.4.0",
        "prisma": "7.5.0",
        "rimraf": "6.1.3",
        "tsc-alias": "1.8.16",
        "tsx": "^4.7.1",
        "typescript": "^5.8.3"
    }
}
